# Supabase 配置示例
# 复制此文件为 .env.local 并填入您的实际值

# Supabase 项目 URL
# 从 https://app.supabase.com/project/_/settings/api 获取
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co

# Supabase 匿名公共密钥（客户端使用）
# 从 Settings → API → Project API keys → anon public 获取
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Supabase 服务角色密钥（仅服务器端使用，用于管理员操作）
# 从 Settings → API → Project API keys → service_role 获取
# ⚠️ 注意：永远不要将此密钥暴露在前端代码中
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Supabase Storage Bucket 名称
SUPABASE_STORAGE_BUCKET=artwork-images

# 可选：iOS App 调用 /api/mobile/device-token 时的共享密钥
# 建议生产环境设置，Header: x-eastwood-mobile-secret
MOBILE_APP_API_SECRET=replace-with-a-long-random-string

# eBay Developer API - Browse API
# 从 https://developer.ebay.com/ → Application Keysets 获取
# EBAY_ENV=production → api.ebay.com; sandbox → api.sandbox.ebay.com
EBAY_APP_ID=your-ebay-app-id-here
EBAY_CERT_ID=your-ebay-cert-id-here
EBAY_ENV=production

# Cron sync secret — used by Vercel cron job to call /api/external/cron-sync
# 生成方式: openssl rand -hex 32
# Vercel cron 每天多次抓取时需要此密钥
CRON_SYNC_SECRET=replace-with-a-long-random-secret

# eBay Marketplace Account Deletion 通知验证令牌
# 32-80 字符，只允许字母、数字、下划线和连字符
EBAY_ACCOUNT_DELETION_VERIFICATION_TOKEN=replace-with-a-long-random-token

# 可选：eBay 删除通知对外公开的完整 HTTPS 地址
# 如果不设置，服务会根据请求头自动推断当前 URL
EBAY_ACCOUNT_DELETION_ENDPOINT_URL=https://your-domain.com/api/ebay/account-deletion

# eBay Browse API (市场监控)
# 从 https://developer.ebay.com → Application Keysets 获取
EBAY_APP_ID=your-ebay-app-id-here
EBAY_CERT_ID=your-ebay-cert-id-here
EBAY_ENV=production
